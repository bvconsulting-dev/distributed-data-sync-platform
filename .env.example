# Database Configuration
DB_CONNECTION_STRING=postgresql://user:password@localhost:5432/sync_db
DB_ENABLE=true
DB_SCHEMA=sync_dev

# IdentityManager API Configuration
identity_REQUEST_RESTAPI_URL=https://api.acme-logistics.com/IdentityManager/v1
identity_REQUEST_RESTAPI_AUTHORIZATION=Bearer your_token_here

# TargetSystem API Configuration
TargetSystem_REQUEST_RESTAPI_URL=https://api.acme-logistics.com/TargetSystem/v1
TargetSystem_DRY_RUN_MODE=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Vault Configuration (Optional)
VAULT_URL=https://vault.acme-logistics.com
VAULT_TOKEN=your_vault_token_here
